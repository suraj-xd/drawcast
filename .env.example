# Required — powers realtime voice agent and diagram generation
OPENAI_API_KEY=

# Optional — override the diagram generation model (default: gpt-5.4-mini)
# OPENAI_DIAGRAM_MODEL=gpt-5.4-mini

# Optional — Deepgram speech-to-text (legacy, not required for realtime voice)
# DEEPGRAM_API_KEY=
# DEEPGRAM_PROJECT_ID=

# Optional — Groq fallback for diagram generation
# GROQ_API_KEY=
